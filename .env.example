# ─────────────────────────────────────────────
# job-automation-pipeline — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to Git — it's in .gitignore.

# ── Google Sheets ──────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Path to your Google Cloud service account JSON key file
GOOGLE_CREDENTIALS_PATH=google_credentials.json

# ── AI APIs ────────────────────────────────────
# DeepSeek API key — get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── File Paths ─────────────────────────────────
# Base directory where scripts read/write CSV files and cover letters
# Examples:
#   Windows: C:\Users\YourName\Desktop
#   Mac/Linux: /home/yourname/job-pipeline
BASE_PATH=C:\Users\YourName\Desktop
